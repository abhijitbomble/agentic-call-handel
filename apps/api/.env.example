# Copy this file to .env and fill in your values
# All variables use the VOICEOPS_ prefix

# ── AI (Claude) ───────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com
VOICEOPS_ANTHROPIC_API_KEY=sk-ant-...
VOICEOPS_DEEPGRAM_API_KEY=dg_...
VOICEOPS_DEEPGRAM_STT_MODEL=nova-3
VOICEOPS_DEEPGRAM_TTS_MODEL=aura-2-thalia-en

# ── Twilio (real phone calls) ─────────────────────────────────────────────────
# Get from: https://console.twilio.com
VOICEOPS_TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VOICEOPS_TWILIO_AUTH_TOKEN=your_auth_token_here
VOICEOPS_TWILIO_PHONE_NUMBER=+14155551234
VOICEOPS_TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VOICEOPS_TWILIO_API_KEY_SECRET=your_twilio_api_key_secret_here
VOICEOPS_TWILIO_TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Number to transfer to when customer asks for a human (your agent's mobile)
VOICEOPS_TWILIO_ESCALATION_NUMBER=+919876543210

# ── Public URL (for Twilio webhooks) ─────────────────────────────────────────
# Run:  ngrok http 8020
# Then copy the https URL here and restart the API
VOICEOPS_PUBLIC_BASE_URL=https://abc123.ngrok.io

# Allow Vercel preview and production domains to call the backend
VOICEOPS_CORS_ORIGIN_REGEX=https://.*\.vercel\.app$

# Set to true in production to verify Twilio request signatures
VOICEOPS_TWILIO_VALIDATE_SIGNATURES=false
